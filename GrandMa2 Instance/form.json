{
  "elements": [
    {
      "type": "ValidationTextBox",
      "name": "ServerAddress",
      "caption": "Server-Adresse / IP"
    },
    {
      "type": "NumberSpinner",
      "name": "ServerPort",
      "caption": "Telnet-Port",
      "minimum": 1,
      "maximum": 65535
    },
    {
      "type": "ValidationTextBox",
      "name": "Username",
      "caption": "Benutzername"
    },
    {
      "type": "PasswordTextBox",
      "name": "Password",
      "caption": "Passwort"
    },
    {
      "type": "Button",
      "caption": "Verbindung testen",
      "onClick": "GMA2_TestConnection($id);"
    }
  ],
  "status": [
    {
      "code": 102,
      "icon": "active",
      "caption": "Verbunden"
    },
    {
      "code": 200,
      "icon": "error",
      "caption": "Server nicht erreichbar"
    },
    {
      "code": 201,
      "icon": "inactive",
      "caption": "Keine Server-Adresse konfiguriert"
    }
  ]
}
